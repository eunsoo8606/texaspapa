<%- include('../layouts/layout', { title: '접수 완료 | 텍사스파파' , head: ` <style>
    .complete-section {
    min-height: 80vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 100px 20px;
    background: #fdfdfd;
    }
    .complete-card {
    background: #fff;
    padding: 60px 40px;
    border-radius: 30px;
    box-shadow: 0 20px 60px rgba(0,0,0,0.05);
    text-align: center;
    max-width: 600px;
    width: 100%;
    border: 1px solid #eee;
    }
    .success-icon-wrap {
    width: 80px;
    height: 80px;
    background: #e6f7ff;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto 30px;
    color: #1890ff;
    font-size: 32px;
    animation: scale-up 0.5s cubic-bezier(0.175, 0.885, 0.32, 1.275);
    }
    @keyframes scale-up {
    from { transform: scale(0); }
    to { transform: scale(1); }
    }
    .complete-title {
    font-size: 32px;
    font-weight: 800;
    color: #1a1a1a;
    margin-bottom: 20px;
    line-height: 1.4;
    }
    .complete-desc {
    font-size: 18px;
    color: #666;
    margin-bottom: 40px;
    line-height: 1.6;
    }
    .home-btn {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    background: #1a1a1a;
    color: #fff;
    padding: 18px 45px;
    border-radius: 50px;
    font-size: 16px;
    font-weight: 700;
    text-decoration: none;
    transition: all 0.3s ease;
    }
    .home-btn:hover {
    background: #ff9800;
    transform: translateY(-3px);
    box-shadow: 0 10px 20px rgba(255, 152, 0, 0.3);
    }

    @media (max-width: 768px) {
    .complete-card { padding: 40px 25px; }
    .complete-title { font-size: 26px; }
    .complete-desc { font-size: 16px; }
    }
    </style>
    `,
    activePage: 'franchise',
    body: `
    <main class="sub-page">
        <!-- Google Tag Manager (noscript) -->
        <noscript><iframe src="https://www.googletagmanager.com/ns.html?id=GTM-MKQ5FKPW" height="0" width="0"
                style="display:none;visibility:hidden"></iframe></noscript>
        <!-- End Google Tag Manager (noscript) -->
        <section class="complete-section">
            <div class="complete-card">
                <div class="success-icon-wrap">
                    <i class="fas fa-check"></i>
                </div>
                <h1 class="complete-title">상담 접수가 완료 되었습니다.</h1>
                <p class="complete-desc">
                    빠른 시간안에 담당자가 연락 드리겠습니다. <br>
                    텍사스파파에 관심을 가져주셔서 감사합니다.
                </p>
                <a href="/" class="home-btn">
                    <span>홈으로</span>
                    <i class="fas fa-home"></i>
                </a>
            </div>
        </section>
    </main>
    `
    }) %>